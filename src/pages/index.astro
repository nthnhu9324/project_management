---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Overview">
	<div class="dashboard-header">
		<div>
			<h1>👋 Welcome back!</h1>
			<p>Here's what's happening across your projects today.</p>
		</div>
		<div class="date-badge glass">
			June 2026
		</div>
	</div>

	<div class="metrics-grid">
		<div class="metric-card glass">
			<h3>Active Brands</h3>
			<div class="value">4</div>
			<div class="trend positive">+1 this month</div>
		</div>
		<div class="metric-card glass">
			<h3>Tasks in Progress</h3>
			<div class="value">12</div>
			<div class="trend">Pending reviews</div>
		</div>
		<div class="metric-card glass">
			<h3>Posts This Month</h3>
			<div class="value">28</div>
			<div class="trend positive">On track</div>
		</div>
	</div>

	<div class="content-grid">
		<div class="panel glass">
			<h2>Overall Progress</h2>
			<div class="brand-progress">
				<div class="brand-info">
					<span>Fujimart</span>
					<span>75%</span>
				</div>
				<div class="progress-container">
					<div class="progress-bar" style="width: 75%"></div>
				</div>
			</div>
			<div class="brand-progress" style="margin-top: 16px;">
				<div class="brand-info">
					<span>Dominos Pizza</span>
					<span>40%</span>
				</div>
				<div class="progress-container">
					<div class="progress-bar" style="width: 40%; background: linear-gradient(90deg, #f59e0b, #ef4444);"></div>
				</div>
			</div>
		</div>
		<div class="panel glass">
			<h2>Upcoming Deadlines</h2>
			<div class="deadline-item">
				<span class="tag warning">Pending</span>
				<div class="details">
					<strong>Fujimart - Bài khai trương</strong>
					<p>Deadline: 25/06/2026</p>
				</div>
			</div>
			<div class="deadline-item">
				<span class="tag danger">Urgent</span>
				<div class="details">
					<strong>Dominos - Promotion Post</strong>
					<p>Deadline: Today</p>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.dashboard-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: 40px;
	}
	.date-badge {
		padding: 8px 16px;
		font-weight: 500;
	}
	
	.metrics-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
		margin-bottom: 40px;
	}
	.metric-card {
		padding: 24px;
	}
	.metric-card h3 {
		font-size: 1rem;
		color: var(--text-muted);
		font-weight: 500;
		margin-bottom: 8px;
	}
	.metric-card .value {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 8px;
	}
	.metric-card .trend {
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.metric-card .trend.positive { color: var(--success); }
	
	.content-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 24px;
	}
	.panel {
		padding: 24px;
	}
	
	.brand-info {
		display: flex;
		justify-content: space-between;
		margin-bottom: 8px;
		font-weight: 500;
	}
	
	.deadline-item {
		display: flex;
		align-items: flex-start;
		gap: 16px;
		margin-top: 16px;
		padding-top: 16px;
		border-top: 1px solid var(--glass-border);
	}
	.deadline-item:first-of-type {
		margin-top: 24px;
	}
	.deadline-item .details strong {
		display: block;
		margin-bottom: 4px;
	}
	.deadline-item .details p {
		font-size: 0.85rem;
		margin: 0;
	}
</style>
