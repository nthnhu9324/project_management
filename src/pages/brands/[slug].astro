---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  return brands.map((brand) => ({
    params: { slug: brand.id },
    props: { brand },
  }));
}

const { brand } = Astro.props;
const {
  title, leader, core_service, overall_progress,
  sheet_url, sheet_embed_url,
  kpi_items, overview_tasks, account_tasks,
  payment_items, contract_items,
} = brand.data;

const initials = title.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();

function stClass(s: string): string {
  const m: Record<string, string> = {
    'Done': 'success', 'Completed': 'success',
    'In Progress': 'warning', 'Processing': 'warning',
    'New Brief': 'primary', 'Not Started': '', 'Pending': 'primary',
    'Canceled': 'danger', 'Tới hạn': 'warning',
  };
  return m[s] ?? '';
}

function getProgressColor(pct: number): string {
  if (pct >= 100) return 'var(--success)';
  if (pct >= 70) return 'var(--warning)';
  if (pct >= 50) return 'var(--accent-primary)';
  return 'var(--danger)';
}
---

<Layout title={title}>

  <!-- ═══ HERO ═══ -->
  <div class="glass-panel hero-section">
    <div class="hero-left">
      <div class="avatar">{initials}</div>
      <div class="hero-info">
        <h1 class="brand-name">{title}</h1>
        <p class="brand-meta">
          {leader && <span class="meta-item">Leader: <strong style="color:var(--text-main);">{leader}</strong></span>}
          {core_service && <span class="meta-item">Service: <strong style="color:var(--text-main);">{core_service}</strong></span>}
        </p>
      </div>
    </div>
    <div class="hero-stat">
      <div class="stat-label">Overall Progress</div>
      <div class="stat-value">{overall_progress}<span class="stat-pct">%</span></div>
      <div class="progress-track" style="width: 140px; margin-top: 12px; margin-left: auto;">
        <div class="progress-fill" style={`width: ${overall_progress}%; background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));`}></div>
      </div>
    </div>
  </div>

  <!-- ═══ KPI CARDS ═══ -->
  {kpi_items && kpi_items.length > 0 && (
    <div class="section-container">
      <h2 class="section-title">KPI Tổng quan</h2>
      <div class="kpi-grid">
        {kpi_items.map((item) => {
          const pct = Math.round((item.post / item.kpi) * 100);
          const color = getProgressColor(pct);
          return (
            <div class="glass-panel kpi-card">
              <div class="kpi-header">
                <span class="kpi-name">{item.label}</span>
                <span class="kpi-badge" style={`color: ${color}; background: ${color}15; border: 1px solid ${color}30;`}>{pct}%</span>
              </div>
              <div class="kpi-numbers">
                <span class="kpi-big">{item.post.toLocaleString()}</span>
                <span class="kpi-of">/ {item.kpi.toLocaleString()}</span>
              </div>
              <div class="progress-track" style="margin-top: 16px;">
                <div class="progress-fill" style={`width: ${Math.min(pct, 100)}%; background: ${color}; box-shadow: 0 0 10px ${color}80;`}></div>
              </div>
              {item.note && <div class="kpi-note">{item.note}</div>}
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- ═══ OVERVIEW TASK ═══ -->
  {overview_tasks && overview_tasks.length > 0 && (
    <div class="section-container">
      <h2 class="section-title">Overview Task</h2>
      <div class="glass-panel" style="overflow: hidden;">
        <div class="table-wrapper">
          <table class="premium-table">
            <thead>
              <tr>
                <th>Task</th>
                <th>Deadline</th>
                <th>Ưu tiên</th>
                <th>Status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {overview_tasks.map((t) => (
                <tr>
                  <td style="font-weight: 500;">{t.task}</td>
                  <td style="color: var(--text-muted);">{t.deadline ?? '—'}</td>
                  <td>{t.priority ? <span class="status-tag danger">{t.priority}</span> : <span style="color: var(--text-muted);">—</span>}</td>
                  <td><span class={`status-tag ${stClass(t.status)}`}>{t.status}</span></td>
                  <td style="color: var(--text-muted);">{t.note ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- ═══ TASK MANAGEMENT ═══ -->
  {account_tasks && account_tasks.length > 0 && (
    <div class="section-container">
      <h2 class="section-title">Task Management</h2>
      <div class="glass-panel" style="overflow: hidden;">
        <div class="table-wrapper">
          <table class="premium-table">
            <thead>
              <tr>
                <th>Hạng mục</th>
                <th>Tiến độ</th>
                <th>DL Internal</th>
                <th>DL EXT/Air</th>
                <th>Status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {account_tasks.map((t) => {
                const color = getProgressColor(t.progress);
                return (
                  <tr>
                    <td style="font-weight: 500;">{t.title}</td>
                    <td>
                      <div style="display: flex; align-items: center; gap: 16px;">
                        <span style={`font-weight: 600; font-size: 0.9rem; color: ${color}; width: 36px; display: inline-block;`}>{t.progress}%</span>
                        <div class="progress-track" style="width: 100px;">
                          <div class="progress-fill" style={`width: ${t.progress}%; background: ${color}; box-shadow: 0 0 8px ${color}60;`}></div>
                        </div>
                      </div>
                    </td>
                    <td style="color: var(--text-muted);">{t.deadline_internal ?? '—'}</td>
                    <td style="color: var(--text-muted);">{t.deadline_ext ?? '—'}</td>
                    <td><span class={`status-tag ${stClass(t.status)}`}>{t.status}</span></td>
                    <td style="color: var(--text-muted);">{t.note ?? '—'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- ═══ THANH TOÁN + HỢP ĐỒNG ═══ -->
  {(payment_items || contract_items) && (
    <div class="split-grid">
      {payment_items && payment_items.length > 0 && (
        <div class="section-container" style="margin-top: 0;">
          <h2 class="section-title">Thanh toán</h2>
          <div class="glass-panel" style="overflow: hidden;">
            <div class="table-wrapper">
              <table class="premium-table">
                <thead>
                  <tr>
                    <th>Đối tác</th>
                    <th>Loại</th>
                    <th>Hạn TT</th>
                    <th>Số tiền</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  {payment_items.map((p) => (
                    <tr>
                      <td style="font-weight: 500;">{p.partner}</td>
                      <td><span class={`status-tag ${p.type === 'THU' ? 'success' : 'primary'}`}>{p.type}</span></td>
                      <td style={p.overdue_days > 0 ? 'color: var(--danger); font-weight: 500;' : 'color: var(--text-muted);'}>
                        {p.due_date}
                        {p.overdue_days > 0 && <span style="font-size: 0.75rem; margin-left: 6px; padding: 2px 6px; background: rgba(239, 68, 68, 0.15); border-radius: 4px;">+{p.overdue_days}d</span>}
                      </td>
                      <td style="font-weight: 500;">{p.amount}đ</td>
                      <td><span class={`status-tag ${stClass(p.status)}`}>{p.status}</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}
      {contract_items && contract_items.length > 0 && (
        <div class="section-container" style="margin-top: 0;">
          <h2 class="section-title">Hợp đồng & BBNT</h2>
          <div class="glass-panel" style="overflow: hidden;">
            <div class="table-wrapper">
              <table class="premium-table">
                <thead>
                  <tr>
                    <th>Bên ký</th>
                    <th>Văn bản</th>
                    <th>Status</th>
                    <th>Note</th>
                  </tr>
                </thead>
                <tbody>
                  {contract_items.map((c) => (
                    <tr>
                      <td style="font-weight: 500;">{c.partner}</td>
                      <td>{c.doc}</td>
                      <td><span class={`status-tag ${stClass(c.status)}`}>{c.status}</span></td>
                      <td style="color: var(--text-muted);">{c.note ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}
    </div>
  )}

  <!-- ═══ IFRAME SHEET ═══ -->
  {sheet_embed_url && (
    <div class="section-container">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 class="section-title" style="margin-bottom: 0;">Data Nguồn (Google Sheet)</h2>
        {sheet_url && (
          <a href={sheet_url} target="_blank" class="glass-panel" style="color: var(--accent-primary); text-decoration: none; font-size: 0.9rem; font-weight: 600; padding: 10px 20px; transition: all 0.2s;">
            Mở toàn màn hình ↗
          </a>
        )}
      </div>
      <div class="glass-panel" style="overflow: hidden; height: 500px; padding: 0;">
        <iframe src={sheet_embed_url} style="width: 100%; height: 100%; border: none;"></iframe>
      </div>
    </div>
  )}

  <!-- ═══ FALLBACK ═══ -->
  {!account_tasks && (
    <div class="section-container">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 class="section-title" style="margin-bottom: 0;">Task Management</h2>
        <a href={`${import.meta.env.BASE_URL}/admin/#/collections/tasks/new`} class="glass-panel" style="color: var(--accent-primary); text-decoration: none; font-size: 0.9rem; font-weight: 600; padding: 10px 20px;">
          + Thêm task mới
        </a>
      </div>
      <div class="glass-panel" style="padding: 64px; text-align: center; color: var(--text-muted); font-size: 1.1rem;">
        Chưa có task nào cho {title}.
      </div>
    </div>
  )}

</Layout>

<style>
  /* Base structural spacing */
  .section-container {
    margin-top: 56px;
  }
  .section-title {
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 24px;
    letter-spacing: 0.02em;
    color: var(--text-main);
  }

  /* Progress bars */
  .progress-track {
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hero Section */
  .hero-section {
    padding: 40px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
  }
  .hero-left {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .avatar {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 20px;
    display: grid;
    place-items: center;
    font-size: 1.8rem;
    font-weight: 700;
    box-shadow: 0 8px 32px rgba(59, 130, 246, 0.3);
  }
  .brand-name {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .brand-meta {
    font-size: 1rem;
    color: var(--text-muted);
    display: flex;
    gap: 16px;
  }
  .meta-item {
    background: rgba(255, 255, 255, 0.03);
    padding: 4px 12px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .hero-stat {
    text-align: right;
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .stat-value {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
  }
  .stat-pct {
    font-size: 1.5rem;
    color: var(--text-muted);
    margin-left: 4px;
  }

  /* KPI Cards Grid */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .kpi-card {
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
  }
  .kpi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
  }
  .kpi-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .kpi-name {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }
  .kpi-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 8px;
  }
  .kpi-numbers {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .kpi-big {
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text-main);
  }
  .kpi-of {
    font-size: 1.1rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  .kpi-note {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 16px;
  }

  /* Layout splits */
  .split-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 56px;
  }

  @media (max-width: 1300px) {
    .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 1024px) {
    .split-grid { grid-template-columns: 1fr; }
  }
</style>
