---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dominos Pizza">
	<div class="brand-header glass">
		<div class="brand-title">
			<div class="logo-placeholder" style="background: linear-gradient(135deg, #ef4444, #b91c1c);">D</div>
			<div>
				<h1>Dominos Pizza</h1>
				<p>Leader: You • Core Service: Khuyến mãi hàng tháng</p>
			</div>
		</div>
		<div class="brand-progress-header">
			<span>Overall Progress: 40%</span>
			<div class="progress-container" style="width: 200px; margin-top: 8px;">
				<div class="progress-bar" style="width: 40%; background: linear-gradient(90deg, #f59e0b, #ef4444);"></div>
			</div>
		</div>
	</div>

	<h2 style="margin-top: 32px;">Task Management</h2>
	<div style="padding: 32px; text-align: center; color: var(--text-muted);" class="glass">
		<p>Chưa có dữ liệu task cho Dominos Pizza.</p>
		<a href={`${import.meta.env.BASE_URL}/admin`} style="color: var(--accent-primary); text-decoration: none; font-weight: 500;">+ Thêm task mới trên CMS</a>
	</div>
</Layout>

<style>
	.brand-header {
		padding: 32px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.brand-title {
		display: flex;
		align-items: center;
		gap: 24px;
	}
	.logo-placeholder {
		width: 64px;
		height: 64px;
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		font-weight: 700;
	}
	.brand-progress-header {
		text-align: right;
		color: var(--text-muted);
	}
</style>
