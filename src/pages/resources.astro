---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resources & Links">
	<div class="dashboard-header">
		<div>
			<h1>Resources & Links</h1>
			<p>Nơi tập hợp các link, template và tài liệu dùng chung.</p>
		</div>
	</div>

	<div style="padding: 32px; text-align: center; color: var(--text-muted);" class="glass">
		<p>Chưa có tài liệu nào.</p>
		<a href={`${import.meta.env.BASE_URL}/admin`} style="color: var(--accent-primary); text-decoration: none; font-weight: 500;">+ Thêm tài liệu mới trên CMS</a>
	</div>
</Layout>
