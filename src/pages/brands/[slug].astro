---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  return brands.map((brand) => ({
    params: { slug: brand.id },
    props: { brand },
  }));
}

const { brand } = Astro.props;
const {
  title, leader, core_service, overall_progress,
  sheet_url, sheet_embed_url,
  kpi_items, overview_tasks, account_tasks,
  payment_items, contract_items,
} = brand.data;

const initials = title.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();

function stClass(s: string): string {
  const m: Record<string, string> = {
    'Done': 'success', 'Completed': 'success',
    'In Progress': 'warning', 'Processing': 'warning',
    'New Brief': 'primary', 'Not Started': '', 'Pending': 'primary',
    'Canceled': 'danger', 'Tới hạn': 'warning',
  };
  return m[s] ?? '';
}

function getProgressColor(pct: number): string {
  if (pct >= 100) return 'var(--success)';
  if (pct >= 70) return 'var(--warning)';
  if (pct >= 50) return 'var(--accent-primary)';
  return 'var(--danger)';
}
---

<Layout title={title}>

  <!-- ═══ HERO ═══ -->
  <div class="hero glass">
    <div class="hero-left">
      <div class="avatar">{initials}</div>
      <div>
        <h1 class="brand-name">{title}</h1>
        <p class="brand-meta">
          {leader && <span>Leader: {leader}</span>}
          {core_service && <span> · {core_service}</span>}
        </p>
      </div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-label">Overall Progress</div>
      <div class="hero-stat-number">{overall_progress}<span class="hero-stat-pct">%</span></div>
      <div class="progress-container" style="width: 140px; margin-top: 8px;">
        <div class="progress-bar" style={`width: ${overall_progress}%`}></div>
      </div>
    </div>
  </div>

  <!-- ═══ KPI CARDS ═══ -->
  {kpi_items && kpi_items.length > 0 && (
    <div class="section-block">
      <h2 class="section-title">KPI Tổng quan</h2>
      <div class="grid-cols-4 kpi-grid">
        {kpi_items.map((item) => {
          const pct = Math.round((item.post / item.kpi) * 100);
          const color = getProgressColor(pct);
          return (
            <div class="glass kpi-card">
              <div class="kpi-top">
                <span class="kpi-name">{item.label}</span>
                <span class="kpi-badge" style={`color: ${color}; background: ${color}20;`}>{pct}%</span>
              </div>
              <div class="kpi-num">
                <span class="kpi-big">{item.post.toLocaleString()}</span>
                <span class="kpi-of">/ {item.kpi.toLocaleString()}</span>
              </div>
              <div class="progress-container" style="margin-top: 12px; height: 4px;">
                <div class="progress-bar" style={`width: ${Math.min(pct, 100)}%; background: ${color};`}></div>
              </div>
              {item.note && <div class="kpi-note">{item.note}</div>}
            </div>
          );
        })}
      </div>
    </div>
  )}

  <!-- ═══ OVERVIEW TASK ═══ -->
  {overview_tasks && overview_tasks.length > 0 && (
    <div class="section-block">
      <h2 class="section-title">Overview Task</h2>
      <div class="table-responsive">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Task</th>
              <th>Deadline</th>
              <th>Ưu tiên</th>
              <th>Status</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            {overview_tasks.map((t) => (
              <tr>
                <td style="font-weight: 500;">{t.task}</td>
                <td style="color: var(--text-muted);">{t.deadline ?? '—'}</td>
                <td>{t.priority ? <span class="tag danger">{t.priority}</span> : <span style="color: var(--text-muted);">—</span>}</td>
                <td><span class={`tag ${stClass(t.status)}`}>{t.status}</span></td>
                <td style="color: var(--text-muted); font-size: 0.9rem;">{t.note ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- ═══ TASK MANAGEMENT ═══ -->
  {account_tasks && account_tasks.length > 0 && (
    <div class="section-block">
      <h2 class="section-title">Task Management</h2>
      <div class="table-responsive">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Hạng mục</th>
              <th>Tiến độ</th>
              <th>DL Internal</th>
              <th>DL EXT/Air</th>
              <th>Status</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            {account_tasks.map((t) => {
              const color = getProgressColor(t.progress);
              return (
                <tr>
                  <td style="font-weight: 500;">{t.title}</td>
                  <td>
                    <div style="display: flex; align-items: center; gap: 12px;">
                      <span style={`font-weight: 600; font-size: 0.85rem; color: ${color}; min-width: 36px;`}>{t.progress}%</span>
                      <div class="progress-container" style="width: 100px; height: 6px;">
                        <div class="progress-bar" style={`width: ${t.progress}%; background: ${color};`}></div>
                      </div>
                    </div>
                  </td>
                  <td style="color: var(--text-muted);">{t.deadline_internal ?? '—'}</td>
                  <td style="color: var(--text-muted);">{t.deadline_ext ?? '—'}</td>
                  <td><span class={`tag ${stClass(t.status)}`}>{t.status}</span></td>
                  <td style="color: var(--text-muted); font-size: 0.9rem;">{t.note ?? '—'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <!-- ═══ THANH TOÁN + HỢP ĐỒNG ═══ -->
  {(payment_items || contract_items) && (
    <div class="grid-cols-2">
      {payment_items && payment_items.length > 0 && (
        <div class="section-block">
          <h2 class="section-title">Thanh toán</h2>
          <div class="table-responsive">
            <table class="modern-table">
              <thead>
                <tr>
                  <th>Đối tác</th>
                  <th>Loại</th>
                  <th>Hạn TT</th>
                  <th>Số tiền</th>
                  <th>Tình trạng</th>
                </tr>
              </thead>
              <tbody>
                {payment_items.map((p) => (
                  <tr>
                    <td style="font-weight: 500;">{p.partner}</td>
                    <td><span class={`tag ${p.type === 'THU' ? 'success' : 'primary'}`}>{p.type}</span></td>
                    <td style={p.overdue_days > 0 ? 'color: var(--danger); font-weight: 500;' : 'color: var(--text-muted);'}>
                      {p.due_date}
                      {p.overdue_days > 0 && <span style="font-size: 0.75rem; margin-left: 4px;">(+{p.overdue_days}d)</span>}
                    </td>
                    <td style="font-weight: 500;">{p.amount}đ</td>
                    <td><span class={`tag ${stClass(p.status)}`}>{p.status}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
      {contract_items && contract_items.length > 0 && (
        <div class="section-block">
          <h2 class="section-title">Hợp đồng & BBNT</h2>
          <div class="table-responsive">
            <table class="modern-table">
              <thead>
                <tr>
                  <th>Bên ký</th>
                  <th>Văn bản</th>
                  <th>Status</th>
                  <th>Note</th>
                </tr>
              </thead>
              <tbody>
                {contract_items.map((c) => (
                  <tr>
                    <td style="font-weight: 500;">{c.partner}</td>
                    <td>{c.doc}</td>
                    <td><span class={`tag ${stClass(c.status)}`}>{c.status}</span></td>
                    <td style="color: var(--text-muted); font-size: 0.9rem;">{c.note ?? '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  )}

  <!-- ═══ IFRAME SHEET ═══ -->
  {sheet_embed_url && (
    <div class="section-block">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h2 class="section-title" style="margin-bottom: 0;">Data Nguồn (Google Sheet)</h2>
        {sheet_url && (
          <a href={sheet_url} target="_blank" style="color: var(--accent-primary); text-decoration: none; font-size: 0.9rem; font-weight: 500; padding: 8px 16px; background: rgba(59, 130, 246, 0.1); border-radius: 8px;">
            Mở toàn màn hình ↗
          </a>
        )}
      </div>
      <div class="iframe-container glass">
        <iframe src={sheet_embed_url}></iframe>
      </div>
    </div>
  )}

  <!-- ═══ FALLBACK ═══ -->
  {!account_tasks && (
    <div class="section-block">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h2 class="section-title" style="margin-bottom: 0;">Task Management</h2>
        <a href={`${import.meta.env.BASE_URL}/admin/#/collections/tasks/new`} style="color: var(--accent-primary); text-decoration: none; font-size: 0.9rem; font-weight: 500;">
          + Thêm task mới
        </a>
      </div>
      <div class="glass" style="padding: 48px; text-align: center; color: var(--text-muted);">
        Chưa có task nào cho {title}.
      </div>
    </div>
  )}

</Layout>

<style>
  .section-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--text-main);
  }

  /* ── HERO ── */
  .hero {
    padding: 32px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    margin-bottom: 48px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
  }
  .hero-left { 
    display: flex; 
    align-items: center; 
    gap: 24px; 
  }
  .avatar {
    width: 64px; 
    height: 64px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 16px;
    display: grid; 
    place-items: center;
    font-size: 1.5rem; 
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.4);
    flex-shrink: 0;
  }
  .brand-name { 
    font-size: 1.75rem; 
    margin-bottom: 4px; 
    font-weight: 700;
  }
  .brand-meta { 
    font-size: 0.95rem; 
    color: var(--text-muted); 
  }
  .hero-stat { 
    text-align: right; 
  }
  .hero-stat-label { 
    font-size: 0.85rem; 
    color: var(--text-muted); 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
    margin-bottom: 8px; 
    font-weight: 600;
  }
  .hero-stat-number { 
    font-size: 2.5rem; 
    font-weight: 700; 
    line-height: 1; 
  }
  .hero-stat-pct { 
    font-size: 1.25rem; 
    color: var(--text-muted); 
    font-weight: 500; 
    margin-left: 4px;
  }

  /* ── KPI CARDS ── */
  .kpi-grid {
    margin-bottom: 48px;
  }
  .kpi-card {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .kpi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2);
  }
  .kpi-top { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
  }
  .kpi-name { 
    font-size: 0.85rem; 
    color: var(--text-muted); 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
    font-weight: 600; 
  }
  .kpi-badge { 
    font-size: 0.75rem; 
    font-weight: 700; 
    padding: 4px 10px; 
    border-radius: 8px; 
  }
  .kpi-num { 
    display: flex; 
    align-items: baseline; 
    gap: 6px; 
    margin-top: 8px;
  }
  .kpi-big { 
    font-size: 2rem; 
    font-weight: 700; 
    line-height: 1; 
    color: var(--text-main);
  }
  .kpi-of { 
    font-size: 1rem; 
    color: var(--text-muted); 
    font-weight: 500;
  }
  .kpi-note { 
    font-size: 0.85rem; 
    color: var(--text-muted); 
    margin-top: 8px;
  }
  
  @media(max-width: 1200px) {
    .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
