---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Fujimart">
	<div class="brand-header glass">
		<div class="brand-title">
			<div class="logo-placeholder">F</div>
			<div>
				<h1>Fujimart</h1>
				<p>Leader: You • Core Service: Khai trương Smart City</p>
			</div>
		</div>
		<div class="brand-progress-header">
			<span>Overall Progress: 75%</span>
			<div class="progress-container" style="width: 200px; margin-top: 8px;">
				<div class="progress-bar" style="width: 75%"></div>
			</div>
		</div>
	</div>

	<h2 style="margin-top: 32px;">Task Management</h2>
	<table class="modern-table">
		<thead>
			<tr>
				<th>Hạng mục</th>
				<th>Post / Content</th>
				<th>Deadline (EXT)</th>
				<th>Status</th>
				<th>Progress</th>
				<th>Action</th>
			</tr>
		</thead>
		<tbody>
			<tr>
				<td>Bài PR</td>
				<td>Bài khai trương Smart City</td>
				<td>25/06/2026</td>
				<td><span class="tag warning">In Progress</span></td>
				<td>70%</td>
				<td><a href="#" style="color: var(--accent-primary)">View Note</a></td>
			</tr>
			<tr>
				<td>Design</td>
				<td>Banner Homepage</td>
				<td>20/06/2026</td>
				<td><span class="tag success">Completed</span></td>
				<td>100%</td>
				<td><a href="#" style="color: var(--accent-primary)">Link Air</a></td>
			</tr>
			<tr>
				<td>Payment</td>
				<td>Thanh toán đợt 1</td>
				<td>30/06/2026</td>
				<td><span class="tag danger">Pending</span></td>
				<td>0%</td>
				<td><a href="#" style="color: var(--accent-primary)">Contract</a></td>
			</tr>
		</tbody>
	</table>
</Layout>

<style>
	.brand-header {
		padding: 32px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.brand-title {
		display: flex;
		align-items: center;
		gap: 24px;
	}
	.logo-placeholder {
		width: 64px;
		height: 64px;
		background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
		border-radius: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2rem;
		font-weight: 700;
	}
	.brand-progress-header {
		text-align: right;
		color: var(--text-muted);
	}
</style>
