---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  return brands.map((brand) => ({
    params: { slug: brand.id },
    props: { brand },
  }));
}

const { brand } = Astro.props;
const {
  title, leader, core_service, overall_progress,
  sheet_url, sheet_embed_url,
  kpi_items, overview_tasks, account_tasks,
  payment_items, contract_items,
} = brand.data;

const initials = title.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();

function statusClass(status: string): string {
  const map: Record<string, string> = {
    'Done': 'success', 'Completed': 'success',
    'In Progress': 'warning', 'Processing': 'warning',
    'New Brief': 'primary', 'Not Started': 'primary', 'Pending': 'primary',
    'Canceled': 'danger',
    'Tới hạn': 'warning',
  };
  return map[status] ?? '';
}

function progressGradient(pct: number): string {
  if (pct >= 90) return 'linear-gradient(90deg, #10b981, #34d399)';
  if (pct >= 50) return 'linear-gradient(90deg, #3b82f6, #8b5cf6)';
  return 'linear-gradient(90deg, #f59e0b, #ef4444)';
}

function kpiColor(pct: number): string {
  if (pct >= 100) return '#34d399';
  if (pct >= 70) return '#fbbf24';
  return '#f87171';
}
---

<Layout title={title}>

  <!-- Brand Header -->
  <section class="hero glass">
    <div class="hero-left">
      <div class="hero-logo">{initials}</div>
      <div class="hero-info">
        <h1 class="hero-title">{title}</h1>
        <p class="hero-subtitle">
          {leader && <span>{leader}</span>}
          {core_service && <span> · {core_service}</span>}
        </p>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-progress-label">Overall Progress</div>
      <div class="hero-progress-row">
        <div class="hero-progress-track">
          <div class="hero-progress-fill" style={`width:${overall_progress}%; background:${progressGradient(overall_progress)}`}></div>
        </div>
        <span class="hero-progress-value">{overall_progress}%</span>
      </div>
    </div>
  </section>

  <!-- KPI Stat Cards -->
  {kpi_items && kpi_items.length > 0 && (
    <section class="section">
      <h2 class="section-title">KPI Tổng quan</h2>
      <div class="kpi-grid">
        {kpi_items.map((item) => {
          const pct = Math.round((item.post / item.kpi) * 100);
          return (
            <div class="kpi-card glass">
              <span class="kpi-label">{item.label}</span>
              <div class="kpi-main">
                <span class="kpi-big" style={`color:${kpiColor(pct)}`}>{item.post.toLocaleString()}</span>
                <span class="kpi-of">/ {item.kpi.toLocaleString()}</span>
              </div>
              <div class="kpi-bar-wrap">
                <div class="kpi-bar" style={`width:${Math.min(pct,100)}%; background:${progressGradient(pct)}`}></div>
              </div>
              <div class="kpi-footer">
                <span class="kpi-pct" style={`color:${kpiColor(pct)}`}>{pct}%</span>
                {item.note && <span class="kpi-note">{item.note}</span>}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Overview Task -->
  {overview_tasks && overview_tasks.length > 0 && (
    <section class="section">
      <h2 class="section-title">Overview Task</h2>
      <div class="card glass">
        <div class="table-responsive">
          <table class="modern-table">
            <thead>
              <tr>
                <th>Task</th>
                <th>Deadline</th>
                <th>Ưu tiên</th>
                <th>Status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {overview_tasks.map((t) => (
                <tr>
                  <td class="cell-bold">{t.task}</td>
                  <td>{t.deadline ?? '—'}</td>
                  <td>
                    {t.priority
                      ? <span class="tag danger">{t.priority}</span>
                      : <span class="cell-muted">—</span>
                    }
                  </td>
                  <td><span class={`tag ${statusClass(t.status)}`}>{t.status}</span></td>
                  <td class="cell-muted">{t.note ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- Account Task (Task Management) -->
  {account_tasks && account_tasks.length > 0 && (
    <section class="section">
      <h2 class="section-title">Task Management</h2>
      <div class="card glass">
        <div class="table-responsive">
          <table class="modern-table">
            <thead>
              <tr>
                <th>Hạng mục</th>
                <th>Tiến độ</th>
                <th>DL Internal</th>
                <th>DL EXT/Air</th>
                <th>Status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {account_tasks.map((t) => (
                <tr>
                  <td class="cell-bold">{t.title}</td>
                  <td>
                    <div class="inline-progress">
                      <span class="inline-progress-value">{t.progress}%</span>
                      <div class="inline-progress-track">
                        <div class="inline-progress-fill" style={`width:${t.progress}%; background:${progressGradient(t.progress)}`}></div>
                      </div>
                    </div>
                  </td>
                  <td>{t.deadline_internal ?? '—'}</td>
                  <td>{t.deadline_ext ?? '—'}</td>
                  <td><span class={`tag ${statusClass(t.status)}`}>{t.status}</span></td>
                  <td class="cell-muted">{t.note ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- Thanh toán + Hợp đồng -->
  {(payment_items || contract_items) && (
    <div class="two-col">
      {payment_items && payment_items.length > 0 && (
        <section class="section">
          <h2 class="section-title">Thanh toán</h2>
          <div class="card glass">
            <div class="table-responsive">
              <table class="modern-table compact">
                <thead>
                  <tr>
                    <th>Đối tác</th>
                    <th>Loại</th>
                    <th>Hạn TT</th>
                    <th>Số tiền</th>
                    <th>Tình trạng</th>
                  </tr>
                </thead>
                <tbody>
                  {payment_items.map((p) => (
                    <tr>
                      <td class="cell-bold">{p.partner}</td>
                      <td><span class={`tag ${p.type === 'THU' ? 'success' : 'primary'}`}>{p.type}</span></td>
                      <td>
                        <span class={p.overdue_days > 0 ? 'cell-danger' : ''}>
                          {p.due_date}
                          {p.overdue_days > 0 && <span class="overdue-badge">+{p.overdue_days}d</span>}
                        </span>
                      </td>
                      <td>{p.amount}đ</td>
                      <td><span class={`tag ${statusClass(p.status)}`}>{p.status}</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      )}

      {contract_items && contract_items.length > 0 && (
        <section class="section">
          <h2 class="section-title">Hợp đồng & BBNT</h2>
          <div class="card glass">
            <div class="table-responsive">
              <table class="modern-table compact">
                <thead>
                  <tr>
                    <th>Bên ký</th>
                    <th>Văn bản</th>
                    <th>Status</th>
                    <th>Note</th>
                  </tr>
                </thead>
                <tbody>
                  {contract_items.map((c) => (
                    <tr>
                      <td class="cell-bold">{c.partner}</td>
                      <td>{c.doc}</td>
                      <td><span class={`tag ${statusClass(c.status)}`}>{c.status}</span></td>
                      <td class="cell-muted">{c.note ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      )}
    </div>
  )}

  <!-- Iframe Google Sheet -->
  {sheet_embed_url && (
    <section class="section">
      <div class="section-header">
        <h2 class="section-title" style="margin-bottom:0;">Data Nguồn (Google Sheet)</h2>
        {sheet_url && (
          <a href={sheet_url} target="_blank" class="link-external">
            Mở toàn màn hình ↗
          </a>
        )}
      </div>
      <div class="iframe-container glass">
        <iframe src={sheet_embed_url}></iframe>
      </div>
    </section>
  )}

  <!-- Fallback: CMS tasks -->
  {!account_tasks && (
    <section class="section">
      <div class="section-header">
        <h2 class="section-title" style="margin-bottom:0;">Task Management</h2>
        <a href={`${import.meta.env.BASE_URL}/admin/#/collections/tasks/new`} class="link-external">
          + Thêm task mới
        </a>
      </div>
      <div class="card glass empty-state">
        <p>Chưa có task nào cho {title}.</p>
      </div>
    </section>
  )}

</Layout>

<style>
  /* Hero */
  .hero {
    padding: 28px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero-left {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .hero-logo {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 14px;
    display: grid;
    place-items: center;
    font-size: 1.3rem;
    font-weight: 700;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.3);
  }
  .hero-title {
    font-size: 1.6rem;
    margin-bottom: 2px;
  }
  .hero-subtitle {
    font-size: 0.9rem;
  }
  .hero-right {
    text-align: right;
    flex-shrink: 0;
  }
  .hero-progress-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .hero-progress-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-progress-track {
    width: 160px;
    height: 8px;
    background: rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
  }
  .hero-progress-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
  }
  .hero-progress-value {
    font-size: 1.1rem;
    font-weight: 700;
    min-width: 40px;
  }

  /* Sections */
  .section {
    margin-top: 32px;
  }
  .section-title {
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 16px;
    letter-spacing: 0.01em;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  /* Cards */
  .card {
    padding: 4px;
    overflow: hidden;
  }

  /* KPI Grid */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 1100px) {
    .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .kpi-card {
    padding: 22px 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
    overflow: hidden;
  }
  .kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
    opacity: 0.5;
  }
  .kpi-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .kpi-main {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 2px;
  }
  .kpi-big {
    font-size: 1.7rem;
    font-weight: 700;
    line-height: 1;
  }
  .kpi-of {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 400;
  }
  .kpi-bar-wrap {
    width: 100%;
    height: 6px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 6px;
  }
  .kpi-bar {
    height: 100%;
    border-radius: 3px;
    transition: width 0.5s ease;
  }
  .kpi-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }
  .kpi-pct {
    font-size: 0.78rem;
    font-weight: 600;
  }
  .kpi-note {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.8;
  }

  /* Two Col */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 32px;
  }
  .two-col .section {
    margin-top: 0;
  }
  @media (max-width: 1024px) {
    .two-col { grid-template-columns: 1fr; }
  }

  /* Table overrides */
  .modern-table.compact td,
  .modern-table.compact th {
    padding: 12px;
    font-size: 0.88rem;
  }

  /* Inline progress in table cells */
  .inline-progress {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .inline-progress-value {
    font-size: 0.8rem;
    font-weight: 600;
    min-width: 34px;
    color: var(--text-main);
  }
  .inline-progress-track {
    width: 80px;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    overflow: hidden;
  }
  .inline-progress-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.4s ease;
  }

  /* Cell utilities */
  .cell-bold { font-weight: 500; }
  .cell-muted { color: var(--text-muted); font-size: 0.88rem; }
  .cell-danger { color: var(--danger); }
  .overdue-badge {
    font-size: 0.7rem;
    background: rgba(239,68,68,0.2);
    color: #f87171;
    padding: 1px 6px;
    border-radius: 4px;
    margin-left: 4px;
  }

  /* Links */
  .link-external {
    color: var(--accent-primary);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }
  .link-external:hover { opacity: 0.8; }

  /* Empty state */
  .empty-state {
    padding: 48px;
    text-align: center;
    color: var(--text-muted);
  }
</style>
